generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- MODELOS ---

model asignaciones_caja_turno {
  id_asignacion_caja_turno Int            @id @default(autoincrement())
  id_caja                  Int
  id_turno                 Int
  id_usuario               Int
  fecha_operacion          DateTime       @default(now()) @db.Date
  estado                   String         @default("ASIGNADA")
  observaciones            String?
  
  caja                     cajas          @relation(fields: [id_caja], references: [id_caja])
  turno                    turnos         @relation(fields: [id_turno], references: [id_turno])
  usuario                  usuarios       @relation(fields: [id_usuario], references: [id_usuario])
  jornada_caja             jornadas_caja?

  @@map("asignaciones_caja_turno")
}

model asignaciones_cocina_pedido {
  id_asignacion_cocina_pedido   Int       @id @default(autoincrement())
  id_pedido                     Int
  id_usuario_cocinero           Int
  estado_asignacion             String    @default("ASIGNADO")
  fecha_hora_asignacion         DateTime  @default(now())
  fecha_hora_aceptacion         DateTime?
  fecha_hora_inicio_preparacion DateTime?
  fecha_hora_listo              DateTime?
  fecha_hora_finalizacion       DateTime?
  es_asignacion_actual          Boolean   @default(true)
  observaciones                 String?

  pedido                        pedidos   @relation(fields: [id_pedido], references: [id_pedido])
  usuario_cocinero              usuarios  @relation(fields: [id_usuario_cocinero], references: [id_usuario])

  @@map("asignaciones_cocina_pedido")
}

model cajas {
  id_caja                 Int                       @id @default(autoincrement())
  nombre                  String                    @unique
  activa                  Boolean                   @default(true)
  asignaciones_caja_turno asignaciones_caja_turno[]

  @@map("cajas")
}

model categorias {
  id_categoria Int         @id @default(autoincrement())
  nombre       String      @unique
  descripcion  String?
  activo       Boolean     @default(true)
  productos    productos[]

  @@map("categorias")
}

model clientes {
  id_cliente        Int        @id @default(autoincrement())
  nombre            String
  apellido          String?
  telefono          String?
  correo_electronico String?
  tipo_cliente      String     @default("NORMAL")
  puntos_fidelidad  Int        @default(0)
  activo            Boolean    @default(true)
  fecha_registro    DateTime   @default(now())
  cliente_ci        Int?
  pedidos           pedidos[]
  reservas          reservas[]

  @@map("clientes")
}

model detalles_pedido {
  id_detalle_pedido        Int                     @id @default(autoincrement())
  id_pedido                Int
  id_presentacion_producto Int
  cantidad                 Int
  precio_unitario          Decimal                 @db.Decimal
  subtotal                 Decimal                 @db.Decimal
  observaciones            String?

  pedido                   pedidos                 @relation(fields: [id_pedido], references: [id_pedido])
  presentacion_producto    presentaciones_producto @relation(fields: [id_presentacion_producto], references: [id_presentacion_producto])

  @@map("detalles_pedido")
}

model facturas {
  id_factura         Int      @id @default(autoincrement())
  id_pedido          Int
  id_usuario_emision Int
  tipo_documento     String   @default("FACTURA")
  numero_documento   String   @unique
  subtotal           Decimal  @db.Decimal
  impuesto           Decimal  @default(0) @db.Decimal
  descuento          Decimal  @default(0) @db.Decimal
  total              Decimal  @db.Decimal
  fecha_emision      DateTime @default(now())
  estado_documento   String   @default("EMITIDA")
  observaciones      String?

  pedido             pedidos  @relation(fields: [id_pedido], references: [id_pedido])
  usuario_emision    usuarios @relation(fields: [id_usuario_emision], references: [id_usuario])

  @@map("facturas")
}

model historial_estados_pedido {
  id_historial_estado_pedido Int      @id @default(autoincrement())
  id_pedido                  Int
  estado                     String
  id_usuario                 Int
  observaciones              String?
  fecha_hora_cambio          DateTime @default(now())

  pedido                     pedidos  @relation(fields: [id_pedido], references: [id_pedido])
  usuario                    usuarios @relation(fields: [id_usuario], references: [id_usuario])

  @@map("historial_estados_pedido")
}

model insumos {
  id_insumo                       Int                               @id @default(autoincrement())
  nombre                          String                            @unique
  unidad_medida                   String
  stock_actual                    Decimal                           @default(0) @db.Decimal
  stock_minimo                    Decimal                           @default(0) @db.Decimal
  activo                          Boolean                           @default(true)
  movimientos_stock               movimientos_stock[]
  recetas_presentaciones_producto recetas_presentaciones_producto[]

  @@map("insumos")
}

model jornadas_caja {
  id_jornada_caja          Int                     @id @default(autoincrement())
  id_asignacion_caja_turno Int                     @unique
  id_usuario_apertura      Int
  id_usuario_cierre        Int?
  fecha_hora_apertura      DateTime                @default(now())
  fecha_hora_cierre        DateTime?
  monto_inicial            Decimal                 @db.Decimal
  monto_teorico_cierre     Decimal                 @default(0) @db.Decimal
  monto_contado_cierre     Decimal?                @db.Decimal
  diferencia_cierre        Decimal                 @default(0) @db.Decimal
  estado                   String                  @default("ABIERTA")

  asignacion_caja_turno    asignaciones_caja_turno @relation(fields: [id_asignacion_caja_turno], references: [id_asignacion_caja_turno])
  usuario_apertura         usuarios                @relation("apertura", fields: [id_usuario_apertura], references: [id_usuario])
  usuario_cierre           usuarios?               @relation("cierre", fields: [id_usuario_cierre], references: [id_usuario])
  movimientos_caja         movimientos_caja[]
  pagos                    pagos[]

  @@map("jornadas_caja")
}

model mesas {
  id_mesa    Int        @id @default(autoincrement())
  id_zona    Int?
  numero     Int        @unique
  capacidad  Int
  estado     String     @default("LIBRE")
  posicion_x Decimal    @default(0) @db.Decimal
  posicion_y Decimal    @default(0) @db.Decimal
  forma      String     @default("CUADRADA")
  activa     Boolean    @default(true)
  zona       zonas?     @relation(fields: [id_zona], references: [id_zona])
  pedidos    pedidos[]
  reservas   reservas[]

  @@map("mesas")
}

model metodos_pago {
  id_metodo_pago Int     @id @default(autoincrement())
  nombre         String  @unique
  pagos          pagos[]

  @@map("metodos_pago")
}

model movimientos_caja {
  id_movimiento_caja    Int           @id @default(autoincrement())
  id_jornada_caja       Int
  id_usuario            Int
  tipo_movimiento       String
  monto                 Decimal       @db.Decimal
  descripcion           String?
  fecha_hora_movimiento DateTime      @default(now())

  jornada_caja          jornadas_caja @relation(fields: [id_jornada_caja], references: [id_jornada_caja])
  usuario               usuarios      @relation(fields: [id_usuario], references: [id_usuario])

  @@map("movimientos_caja")
}

model movimientos_stock {
  id_movimiento_stock Int      @id @default(autoincrement())
  id_insumo           Int
  id_usuario          Int?
  tipo_movimiento     String
  cantidad            Decimal  @db.Decimal
  motivo              String?
  fecha_registro      DateTime @default(now())

  insumo              insumos  @relation(fields: [id_insumo], references: [id_insumo])
  usuario             usuarios? @relation(fields: [id_usuario], references: [id_usuario])

  @@map("movimientos_stock")
}

model pagos {
  id_pago           Int           @id @default(autoincrement())
  id_pedido         Int
  id_metodo_pago    Int
  id_jornada_caja   Int?
  id_usuario_cajero Int
  monto_pagado      Decimal       @db.Decimal
  monto_recibido    Decimal?      @db.Decimal
  monto_cambio      Decimal       @default(0) @db.Decimal
  referencia_pago   String?
  estado_pago       String        @default("CONFIRMADO")
  observacion       String?
  fecha_hora_pago   DateTime      @default(now())

  pedido            pedidos       @relation(fields: [id_pedido], references: [id_pedido])
  metodo_pago       metodos_pago  @relation(fields: [id_metodo_pago], references: [id_metodo_pago])
  jornada_caja      jornadas_caja? @relation(fields: [id_jornada_caja], references: [id_jornada_caja])
  usuario_cajero    usuarios      @relation(fields: [id_usuario_cajero], references: [id_usuario])

  @@map("pagos")
}

model pedidos {
  id_pedido                Int                          @id @default(autoincrement())
  id_tipo_pedido           Int
  id_cliente               Int?
  id_mesa                  Int?
  id_usuario_mesero        Int?
  estado                   String                       @default("REGISTRADO")
  tiempo_estimado_minutos  Int                          @default(0)
  subtotal                 Decimal                      @default(0) @db.Decimal
  impuesto                 Decimal                      @default(0) @db.Decimal
  descuento                Decimal                      @default(0) @db.Decimal
  total                    Decimal                      @default(0) @db.Decimal
  observaciones            String?
  fecha_hora_pedido        DateTime                     @default(now())
  fecha_hora_entrega       DateTime?

  tipo_pedido              tipos_pedido                 @relation(fields: [id_tipo_pedido], references: [id_tipo_pedido])
  cliente                  clientes?                    @relation(fields: [id_cliente], references: [id_cliente])
  mesa                     mesas?                       @relation(fields: [id_mesa], references: [id_mesa])
  usuario_mesero           usuarios?                    @relation(fields: [id_usuario_mesero], references: [id_usuario])
  asignaciones_cocina      asignaciones_cocina_pedido[]
  detalles_pedido          detalles_pedido[]
  facturas                 facturas[]
  historial_estados        historial_estados_pedido[]
  pagos                    pagos[]
  pedido_delivery          pedidos_delivery?

  @@map("pedidos")
}

model pedidos_delivery {
  id_pedido_delivery    Int       @id @default(autoincrement())
  id_pedido             Int       @unique
  id_usuario_repartidor Int?
  nombre_contacto       String
  telefono_contacto     String
  direccion_entrega     String
  referencia_entrega    String?
  latitud_entrega       Decimal?  @db.Decimal
  longitud_entrega      Decimal?  @db.Decimal
  costo_entrega         Decimal   @default(0) @db.Decimal
  estado_delivery       String    @default("PENDIENTE")
  fecha_hora_salida     DateTime?

  pedido                pedidos   @relation(fields: [id_pedido], references: [id_pedido])
  usuario_repartidor    usuarios? @relation(fields: [id_usuario_repartidor], references: [id_usuario])

  @@map("pedidos_delivery")
}

model presentaciones_producto {
  id_presentacion_producto Int                               @id @default(autoincrement())
  id_producto               Int
  nombre                    String
  precio                    Decimal                           @db.Decimal
  tiempo_preparacion_minutos Int                               @default(10)
  disponible                Boolean                           @default(true)
  activo                    Boolean                           @default(true)
  es_predeterminada         Boolean                           @default(false)
  producto                  productos                         @relation(fields: [id_producto], references: [id_producto])
  detalles_pedido           detalles_pedido[]
  recetas_presentaciones    recetas_presentaciones_producto[]

  @@map("presentaciones_producto")
}

model productos {
  id_producto    Int                       @id @default(autoincrement())
  id_categoria   Int
  nombre         String                    @unique
  descripcion    String?
  imagen_url     String?
  disponible     Boolean                   @default(true)
  activo         Boolean                   @default(true)
  categoria      categorias                @relation(fields: [id_categoria], references: [id_categoria])
  presentaciones presentaciones_producto[]

  @@map("productos")
}

model recetas_presentaciones_producto {
  id_receta_presentacion_producto Int                     @id @default(autoincrement())
  id_presentacion_producto        Int
  id_insumo                       Int
  cantidad_insumo                 Decimal                 @db.Decimal
  presentacion_producto           presentaciones_producto @relation(fields: [id_presentacion_producto], references: [id_presentacion_producto])
  insumo                          insumos                 @relation(fields: [id_insumo], references: [id_insumo])

  @@map("recetas_presentaciones_producto")
}

model reservas {
  id_reserva          Int      @id @default(autoincrement())
  id_cliente          Int?
  id_mesa             Int
  id_usuario          Int
  fecha_hora_reserva  DateTime
  cantidad_personas   Int
  estado              String   @default("CONFIRMADA")
  observaciones       String?
  fecha_registro      DateTime @default(now())

  cliente             clientes? @relation(fields: [id_cliente], references: [id_cliente])
  mesa                mesas    @relation(fields: [id_mesa], references: [id_mesa])
  usuario             usuarios @relation(fields: [id_usuario], references: [id_usuario])

  @@map("reservas")
}

model roles {
  id_rol   Int        @id @default(autoincrement())
  nombre   String     @unique
  usuarios usuarios[]

  @@map("roles")
}

model tipos_pedido {
  id_tipo_pedido Int       @id @default(autoincrement())
  nombre         String    @unique
  pedidos        pedidos[]

  @@map("tipos_pedido")
}

model turnos {
  id_turno                Int                       @id @default(autoincrement())
  nombre                  String                    @unique
  hora_inicio             DateTime                  @db.Time
  hora_fin                DateTime                  @db.Time
  activo                  Boolean                   @default(true)
  asignaciones_caja_turno asignaciones_caja_turno[]

  @@map("turnos")
}

model usuarios {
  id_usuario                 Int                          @id @default(autoincrement())
  id_rol                     Int
  usuario_ci                 Int                          @unique
  nombre                     String
  apellido                   String?
  nombre_usuario             String                       @unique
  contrasena_hash            String
  telefono                   String?
  correo_electronico         String?                      @unique
  activo                     Boolean                      @default(true)
  fecha_creacion             DateTime                     @default(now())

  rol                        roles                        @relation(fields: [id_rol], references: [id_rol])
  asignaciones_caja_turno    asignaciones_caja_turno[]
  asignaciones_cocina        asignaciones_cocina_pedido[]
  facturas                   facturas[]
  historial_estados          historial_estados_pedido[]
  jornadas_apertura          jornadas_caja[]              @relation("apertura")
  jornadas_cierre            jornadas_caja[]              @relation("cierre")
  movimientos_caja           movimientos_caja[]
  movimientos_stock          movimientos_stock[]
  pagos                      pagos[]
  pedidos_mesero             pedidos[]
  pedidos_repartidor         pedidos_delivery[]
  reservas                   reservas[]

  @@map("usuarios")
}

model zonas {
  id_zona     Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?
  mesas       mesas[]

  @@map("zonas")
}
