generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model asignaciones_caja_turno {
  id_asignacion_caja_turno Int            @id @default(autoincrement())
  id_caja                  Int
  id_turno                 Int
  id_usuario_cajero        Int
  fecha_operacion          DateTime       @default(dbgenerated("CURRENT_DATE")) @db.Date
  estado                   String         @default("ASIGNADA") @db.VarChar
  observaciones            String?
  caja                     cajas          @relation(fields: [id_caja], references: [id_caja], onDelete: NoAction, onUpdate: NoAction)
  turno                    turnos         @relation(fields: [id_turno], references: [id_turno], onDelete: NoAction, onUpdate: NoAction)
  usuarios                 usuarios       @relation(fields: [id_usuario_cajero], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  jornada_caja             jornadas_caja?

  @@index([id_caja], map: "idx_asignaciones_caja_turno_id_caja")
  @@index([id_turno], map: "idx_asignaciones_caja_turno_id_turno")
  @@index([id_usuario_cajero], map: "idx_asignaciones_caja_turno_id_usuario_cajero")
  @@map("asignaciones_caja_turno")
}

model asignaciones_cocina_pedido {
  id_asignacion_cocina_pedido   Int       @id @default(autoincrement())
  id_pedido                     Int
  id_usuario_cocinero           Int
  estado_asignacion             String    @default("ASIGNADO") @db.VarChar
  fecha_hora_asignacion         DateTime  @default(now()) @db.Timestamp(6)
  fecha_hora_aceptacion         DateTime? @db.Timestamp(6)
  fecha_hora_inicio_preparacion DateTime? @db.Timestamp(6)
  fecha_hora_listo              DateTime? @db.Timestamp(6)
  fecha_hora_finalizacion       DateTime? @db.Timestamp(6)
  es_asignacion_actual          Boolean   @default(true)
  observaciones                 String?
  pedido                        pedidos   @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  usuario_cocinero              usuarios  @relation(fields: [id_usuario_cocinero], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_asignaciones_cocina_pedido_id_pedido")
  @@index([id_usuario_cocinero], map: "idx_asignaciones_cocina_pedido_id_usuario_cocinero")
  @@map("asignaciones_cocina_pedido")
}

model cajas {
  id_caja                 Int                       @id @default(autoincrement())
  nombre                  String                    @unique @db.VarChar
  activa                  Boolean                   @default(true)
  asignaciones_caja_turno asignaciones_caja_turno[]

  @@map("cajas")
}

model categorias {
  id_categoria Int         @id @default(autoincrement())
  nombre       String      @unique @db.VarChar
  descripcion  String?
  activo       Boolean     @default(true)
  productos    productos[]

  @@map("categorias")
}

model detalles_pedido {
  id_detalle_pedido        Int                     @id @default(autoincrement())
  id_pedido                Int
  id_presentacion_producto Int
  cantidad                 Int
  precio_unitario          Decimal                 @db.Decimal
  subtotal                 Decimal                 @db.Decimal
  observaciones            String?
  pedido                   pedidos                 @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  presentacion_producto    presentaciones_producto @relation(fields: [id_presentacion_producto], references: [id_presentacion_producto], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_detalles_pedido_id_pedido")
  @@index([id_presentacion_producto], map: "idx_detalles_pedido_id_presentacion_producto")
  @@map("detalles_pedido")
}

model facturas {
  id_factura         Int      @id @default(autoincrement())
  id_pedido          Int
  id_usuario_emision Int
  tipo_documento     String   @default("FACTURA") @db.VarChar
  numero_documento   String   @unique @db.VarChar
  subtotal           Decimal  @db.Decimal
  impuesto           Decimal  @default(0) @db.Decimal
  descuento          Decimal  @default(0) @db.Decimal
  total              Decimal  @db.Decimal
  fecha_emision      DateTime @default(now()) @db.Timestamp(6)
  estado_documento   String   @default("EMITIDA") @db.VarChar
  observaciones      String?
  pedido             pedidos  @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  usuario_emision    usuarios @relation(fields: [id_usuario_emision], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_facturas_id_pedido")
  @@index([id_usuario_emision], map: "idx_facturas_id_usuario_emision")
  @@map("facturas")
}

model historial_estados_pedido {
  id_historial_estado_pedido Int      @id @default(autoincrement())
  id_pedido                  Int
  id_usuario                 Int
  estado                     String   @db.VarChar
  observaciones              String?
  fecha_hora_cambio          DateTime @default(now()) @db.Timestamp(6)
  pedido                     pedidos  @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  usuario                    usuarios @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_historial_estados_pedido_id_pedido")
  @@index([id_usuario], map: "idx_historial_estados_pedido_id_usuario")
  @@map("historial_estados_pedido")
}

model insumos {
  id_insumo                       Int                               @id @default(autoincrement())
  nombre                          String                            @unique @db.VarChar
  unidad_medida                   String                            @db.VarChar
  stock_actual                    Decimal                           @default(0) @db.Decimal
  stock_minimo                    Decimal                           @default(0) @db.Decimal
  activo                          Boolean                           @default(true)
  movimientos_stock               movimientos_stock[]
  recetas_presentaciones_producto recetas_presentaciones_producto[]

  @@map("insumos")
}

model jornadas_caja {
  id_jornada_caja          Int                     @id @default(autoincrement())
  id_asignacion_caja_turno Int                     @unique
  id_usuario_apertura      Int
  id_usuario_cierre        Int?
  fecha_hora_apertura      DateTime                @default(now()) @db.Timestamp(6)
  fecha_hora_cierre        DateTime?               @db.Timestamp(6)
  monto_inicial            Decimal                 @db.Decimal
  monto_teorico_cierre     Decimal                 @default(0) @db.Decimal
  monto_contado_cierre     Decimal?                @db.Decimal
  diferencia_cierre        Decimal                 @default(0) @db.Decimal
  estado                   String                  @default("ABIERTA") @db.VarChar
  asignacion_caja_turno    asignaciones_caja_turno @relation(fields: [id_asignacion_caja_turno], references: [id_asignacion_caja_turno], onDelete: NoAction, onUpdate: NoAction)
  usuario_apertura         usuarios                @relation("apertura", fields: [id_usuario_apertura], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  usuario_cierre           usuarios?               @relation("cierre", fields: [id_usuario_cierre], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  movimientos_caja         movimientos_caja[]
  pagos                    pagos[]

  @@index([id_usuario_apertura], map: "idx_jornadas_caja_id_usuario_apertura")
  @@index([id_usuario_cierre], map: "idx_jornadas_caja_id_usuario_cierre")
  @@map("jornadas_caja")
}

model mesas {
  id_mesa    Int        @id @default(autoincrement())
  id_zona    Int?
  numero     Int        @unique
  capacidad  Int
  estado     String     @default("LIBRE") @db.VarChar
  posicion_x Decimal    @default(0) @db.Decimal
  posicion_y Decimal    @default(0) @db.Decimal
  forma      String     @default("CUADRADA") @db.VarChar
  activa     Boolean    @default(true)
  zona       zonas?     @relation(fields: [id_zona], references: [id_zona], onDelete: NoAction, onUpdate: NoAction)
  pedidos    pedidos[]
  reservas   reservas[]

  @@index([id_zona], map: "idx_mesas_id_zona")
  @@map("mesas")
}

model metodos_pago {
  id_metodo_pago Int     @id @default(autoincrement())
  nombre         String  @unique @db.VarChar
  pagos          pagos[]

  @@map("metodos_pago")
}

model movimientos_caja {
  id_movimiento_caja    Int           @id @default(autoincrement())
  id_jornada_caja       Int
  id_usuario            Int
  tipo_movimiento       String        @db.VarChar
  monto                 Decimal       @db.Decimal
  descripcion           String?
  fecha_hora_movimiento DateTime      @default(now()) @db.Timestamp(6)
  jornada_caja          jornadas_caja @relation(fields: [id_jornada_caja], references: [id_jornada_caja], onDelete: NoAction, onUpdate: NoAction)
  usuario               usuarios      @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_jornada_caja], map: "idx_movimientos_caja_id_jornada_caja")
  @@index([id_usuario], map: "idx_movimientos_caja_id_usuario")
  @@map("movimientos_caja")
}

model movimientos_stock {
  id_movimiento_stock Int       @id @default(autoincrement())
  id_insumo           Int
  id_usuario          Int?
  tipo_movimiento     String    @db.VarChar
  cantidad            Decimal   @db.Decimal
  motivo              String?
  fecha_registro      DateTime  @default(now()) @db.Timestamp(6)
  insumo              insumos   @relation(fields: [id_insumo], references: [id_insumo], onDelete: NoAction, onUpdate: NoAction)
  usuario             usuarios? @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_insumo], map: "idx_movimientos_stock_id_insumo")
  @@index([id_usuario], map: "idx_movimientos_stock_id_usuario")
  @@map("movimientos_stock")
}

model pagos {
  id_pago           Int            @id @default(autoincrement())
  id_pedido         Int
  id_metodo_pago    Int
  id_jornada_caja   Int?
  id_usuario_cajero Int
  monto_pagado      Decimal        @db.Decimal
  monto_recibido    Decimal?       @db.Decimal
  monto_cambio      Decimal        @default(0) @db.Decimal
  referencia_pago   String?        @db.VarChar
  estado_pago       String         @default("CONFIRMADO") @db.VarChar
  observacion       String?
  fecha_hora_pago   DateTime       @default(now()) @db.Timestamp(6)
  jornada_caja      jornadas_caja? @relation(fields: [id_jornada_caja], references: [id_jornada_caja], onDelete: NoAction, onUpdate: NoAction)
  metodo_pago       metodos_pago   @relation(fields: [id_metodo_pago], references: [id_metodo_pago], onDelete: NoAction, onUpdate: NoAction)
  pedido            pedidos        @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  usuario_cajero    usuarios       @relation(fields: [id_usuario_cajero], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_jornada_caja], map: "idx_pagos_id_jornada_caja")
  @@index([id_metodo_pago], map: "idx_pagos_id_metodo_pago")
  @@index([id_pedido], map: "idx_pagos_id_pedido")
  @@index([id_usuario_cajero], map: "idx_pagos_id_usuario_cajero")
  @@map("pagos")
}

model pedidos {
  id_pedido                                     Int                          @id @default(autoincrement())
  id_tipo_pedido                                Int
  id_usuario_cliente                            Int?
  id_mesa                                       Int?
  id_usuario_mesero                             Int?
  estado                                        String                       @default("REGISTRADO") @db.VarChar
  tiempo_estimado_minutos                       Int                          @default(0)
  subtotal                                      Decimal                      @default(0) @db.Decimal
  impuesto                                      Decimal                      @default(0) @db.Decimal
  descuento                                     Decimal                      @default(0) @db.Decimal
  total                                         Decimal                      @default(0) @db.Decimal
  observaciones                                 String?
  fecha_hora_pedido                             DateTime                     @default(now()) @db.Timestamp(6)
  fecha_hora_entrega                            DateTime?                    @db.Timestamp(6)
  asignaciones_cocina                           asignaciones_cocina_pedido[]
  detalles_pedido                               detalles_pedido[]
  facturas                                      facturas[]
  historial_estados                             historial_estados_pedido[]
  pagos                                         pagos[]
  mesa                                          mesas?                       @relation(fields: [id_mesa], references: [id_mesa], onDelete: NoAction, onUpdate: NoAction)
  tipo_pedido                                   tipos_pedido                 @relation(fields: [id_tipo_pedido], references: [id_tipo_pedido], onDelete: NoAction, onUpdate: NoAction)
  usuarios_pedidos_id_usuario_clienteTousuarios usuarios?                    @relation("pedidos_id_usuario_clienteTousuarios", fields: [id_usuario_cliente], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  usuario_mesero                                usuarios?                    @relation(fields: [id_usuario_mesero], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  pedido_delivery                               pedidos_delivery?

  @@index([id_mesa], map: "idx_pedidos_id_mesa")
  @@index([id_tipo_pedido], map: "idx_pedidos_id_tipo_pedido")
  @@index([id_usuario_cliente], map: "idx_pedidos_id_usuario_cliente")
  @@index([id_usuario_mesero], map: "idx_pedidos_id_usuario_mesero")
  @@map("pedidos")
}

model pedidos_delivery {
  id_pedido_delivery    Int       @id @default(autoincrement())
  id_pedido             Int       @unique
  id_usuario_repartidor Int?
  nombre_contacto       String    @db.VarChar
  telefono_contacto     String    @db.VarChar
  direccion_entrega     String
  referencia_entrega    String?
  latitud_entrega       Decimal?  @db.Decimal
  longitud_entrega      Decimal?  @db.Decimal
  costo_entrega         Decimal   @default(0) @db.Decimal
  estado_delivery       String    @default("PENDIENTE") @db.VarChar
  fecha_hora_salida     DateTime? @db.Timestamp(6)
  pedido                pedidos   @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  usuario_repartidor    usuarios? @relation(fields: [id_usuario_repartidor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_pedidos_delivery_id_pedido")
  @@index([id_usuario_repartidor], map: "idx_pedidos_delivery_id_usuario_repartidor")
  @@map("pedidos_delivery")
}

model presentaciones_producto {
  id_presentacion_producto   Int                               @id @default(autoincrement())
  id_producto                Int
  nombre                     String                            @db.VarChar
  precio                     Decimal                           @db.Decimal
  tiempo_preparacion_minutos Int                               @default(10)
  disponible                 Boolean                           @default(true)
  activo                     Boolean                           @default(true)
  es_predeterminada          Boolean                           @default(false)
  detalles_pedido            detalles_pedido[]
  producto                   productos                         @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction)
  recetas_presentaciones     recetas_presentaciones_producto[]

  @@index([id_producto], map: "idx_presentaciones_producto_id_producto")
  @@map("presentaciones_producto")
}

model productos {
  id_producto        Int                       @id @default(autoincrement())
  id_categoria       Int
  nombre             String                    @unique @db.VarChar
  descripcion        String?
  imagen_url         String?
  disponible         Boolean                   @default(true)
  activo             Boolean                   @default(true)
  precio             Decimal?                  @db.Decimal
  tiempo_preparacion Int?
  presentaciones     presentaciones_producto[]
  categoria          categorias                @relation(fields: [id_categoria], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_categoria], map: "idx_productos_id_categoria")
  @@map("productos")
}

model recetas_presentaciones_producto {
  id_receta_presentacion_producto Int                     @id @default(autoincrement())
  id_presentacion_producto        Int
  id_insumo                       Int
  cantidad_insumo                 Decimal                 @db.Decimal
  insumo                          insumos                 @relation(fields: [id_insumo], references: [id_insumo], onDelete: NoAction, onUpdate: NoAction)
  presentacion_producto           presentaciones_producto @relation(fields: [id_presentacion_producto], references: [id_presentacion_producto], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_insumo], map: "idx_recetas_presentaciones_producto_id_insumo")
  @@index([id_presentacion_producto], map: "idx_recetas_presentaciones_producto_id_presentacion")
  @@map("recetas_presentaciones_producto")
}

model reservas {
  id_reserva                                      Int       @id @default(autoincrement())
  id_usuario_cliente                              Int?
  id_mesa                                         Int
  id_usuario_registro                             Int
  fecha_hora_reserva                              DateTime  @db.Timestamp(6)
  cantidad_personas                               Int
  estado                                          String    @default("CONFIRMADA") @db.VarChar
  observaciones                                   String?
  fecha_registro                                  DateTime  @default(now()) @db.Timestamp(6)
  mesa                                            mesas     @relation(fields: [id_mesa], references: [id_mesa], onDelete: NoAction, onUpdate: NoAction)
  usuarios_reservas_id_usuario_clienteTousuarios  usuarios? @relation("reservas_id_usuario_clienteTousuarios", fields: [id_usuario_cliente], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  usuarios_reservas_id_usuario_registroTousuarios usuarios  @relation("reservas_id_usuario_registroTousuarios", fields: [id_usuario_registro], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_mesa], map: "idx_reservas_id_mesa")
  @@index([id_usuario_cliente], map: "idx_reservas_id_usuario_cliente")
  @@index([id_usuario_registro], map: "idx_reservas_id_usuario_registro")
  @@map("reservas")
}

model roles {
  id_rol   Int        @id @default(autoincrement())
  nombre   String     @unique @db.VarChar
  usuarios usuarios[]

  @@map("roles")
}

model tipos_pedido {
  id_tipo_pedido Int       @id @default(autoincrement())
  nombre         String    @unique @db.VarChar
  pedidos        pedidos[]

  @@map("tipos_pedido")
}

model turnos {
  id_turno                Int                       @id @default(autoincrement())
  nombre                  String                    @unique @db.VarChar
  hora_inicio             DateTime                  @db.Time(6)
  hora_fin                DateTime                  @db.Time(6)
  activo                  Boolean                   @default(true)
  asignaciones_caja_turno asignaciones_caja_turno[]

  @@map("turnos")
}

model usuarios {
  id_usuario                                      Int                          @id @default(autoincrement())
  id_rol                                          Int
  id_tipo_cliente                                 Int?
  usuario_ci                                      Int                          @unique
  nombre                                          String                       @db.VarChar
  apellido                                        String?                      @db.VarChar
  nombre_usuario                                  String                       @unique @db.VarChar
  contrasena_hash                                 String
  telefono                                        String?                      @db.VarChar
  correo_electronico                              String?                      @unique @db.VarChar
  puntos_fidelidad                                Int                          @default(0)
  activo                                          Boolean                      @default(true)
  fecha_creacion                                  DateTime                     @default(now()) @db.Timestamp(6)
  codigo_recuperacion                             String?                      @db.VarChar
  expiracion_recuperacion                         DateTime?                    @db.Timestamp(6)
  asignaciones_caja_turno                         asignaciones_caja_turno[]
  asignaciones_cocina                             asignaciones_cocina_pedido[]
  facturas                                        facturas[]
  historial_estados                               historial_estados_pedido[]
  jornadas_apertura                               jornadas_caja[]              @relation("apertura")
  jornadas_cierre                                 jornadas_caja[]              @relation("cierre")
  movimientos_caja                                movimientos_caja[]
  movimientos_stock                               movimientos_stock[]
  pagos                                           pagos[]
  pedidos_pedidos_id_usuario_clienteTousuarios    pedidos[]                    @relation("pedidos_id_usuario_clienteTousuarios")
  pedidos_mesero                                  pedidos[]
  pedidos_repartidor                              pedidos_delivery[]
  reservas_reservas_id_usuario_clienteTousuarios  reservas[]                   @relation("reservas_id_usuario_clienteTousuarios")
  reservas_reservas_id_usuario_registroTousuarios reservas[]                   @relation("reservas_id_usuario_registroTousuarios")
  rol                                             roles                        @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  tipos_cliente                                   tipos_cliente?               @relation(fields: [id_tipo_cliente], references: [id_tipo_cliente], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_rol], map: "idx_usuarios_id_rol")
  @@index([id_tipo_cliente], map: "idx_usuarios_id_tipo_cliente")
  @@map("usuarios")
}

model zonas {
  id_zona     Int     @id @default(autoincrement())
  nombre      String  @unique @db.VarChar
  descripcion String?
  activo      Boolean @default(true)
  mesas       mesas[]

  @@map("zonas")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tipos_cliente {
  id_tipo_cliente Int        @id @default(autoincrement())
  nombre_tipo     String     @unique @db.VarChar
  descripcion     String?    @db.VarChar
  usuarios        usuarios[]
}
